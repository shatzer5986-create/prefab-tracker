generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id        Int      @id @default(autoincrement())
  jobNumber String   @unique @map("job_number")
  name      String
  customer  String?
  status    String?  @default("Active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("jobs")
}

model JobStock {
  id               Int      @id @default(autoincrement())
  jobNumber        String   @map("job_number")
  materialName     String   @map("material_name")
  description      String?
  unit             String
  quantity         Decimal  @default(0) @db.Decimal(12, 2)
  vendor           String?
  poNumber         String?  @map("po_number")
  location         String?
  status           String?  @default("available")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("job_stock")
}

model MaterialCatalog {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  category      String?
  defaultUnit   String?  @map("default_unit")
  defaultVendor String?  @map("default_vendor")
  description   String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("material_catalog")
}

model Material {
  id           Int      @id @default(autoincrement())
  job          String
  item         String
  category     String
  orderedQty   Int      @default(0) @map("ordered_qty")
  receivedQty  Int      @default(0) @map("received_qty")
  allocatedQty Int      @default(0) @map("allocated_qty")
  unit         String
  vendor       String
  status       String
  location     String
  poNumber     String?  @map("po_number")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("materials")
}

model Tool {
  id                Int      @id @default(autoincrement())
  category          String?
  barcode           String?
  itemNumber        String?  @map("item_number")
  manufacturer      String?
  model             String?
  description       String?
  quantityAvailable Int      @default(0) @map("quantity_available")
  jobNumber         String?  @map("job_number")
  assignmentType    String   @default("Shop") @map("assignment_type")
  assignedTo        String?  @map("assigned_to")
  toolRoomLocation  String?  @map("tool_room_location")
  serialNumber      String?  @map("serial_number")
  transferDateIn    String?  @map("transfer_date_in")
  transferDateOut   String?  @map("transfer_date_out")
  status            String   @default("Working")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("tools")
}